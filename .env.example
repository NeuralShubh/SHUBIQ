# Supabase URL + publishable key (safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key-here

# Supabase secret/service role key (server only - never expose in browser code)
SUPABASE_SERVICE_ROLE_KEY=your-secret-service-role-key-here

# Optional direct DB connection string
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# Public site URL (used for SEO metadata, sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://shubiq.com

# Admin panel password (change this!)
NEXT_PUBLIC_ADMIN_PASSWORD=shubiq_admin_2024
